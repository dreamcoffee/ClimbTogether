<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="Workout">
    <insert id="save" parameterType="com.climbing.climbing_web.entity.WorkoutEntity"
            useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO workout (
                member_id,
                gym_name,
                record_date,
                difficulty_color,
                solved_count
        )
        VALUES (
                   #{memberId},
                   #{gymName},
--                    #{recordDate},
                   #{difficultyColor},
                   #{solvedCount})
    </insert>
</mapper>